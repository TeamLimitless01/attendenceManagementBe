{
  "kind": "collectionType",
  "collectionName": "students",
  "info": {
    "singularName": "student",
    "pluralName": "students",
    "displayName": "Student"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "roll_number": {
      "type": "string"
    },
    "device_id": {
      "type": "string"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "student"
    },
    "faceEmbedding": {
      "type": "json"
    },
    "isFaceRegistered": {
      "type": "boolean",
      "default": false
    },
    "class": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::class.class",
      "inversedBy": "students"
    },
    "attendences": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::attendence.attendence",
      "mappedBy": "student"
    },
    "lecture": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::lecture.lecture",
      "inversedBy": "students"
    },
    "name": {
      "type": "string"
    },
    "photo": {
      "type": "string"
    }
